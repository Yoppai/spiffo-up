{
  "name": "spiffo-up",
  "version": "1.0.0",
  "description": "CLI TUI tool built with Bun + Ink + React + Zustand",
  "module": "index.tsx",
  "type": "module",
  "bin": {
    "spiffo-up": "./index.tsx"
    },
  "scripts": {
    "dev": "bun --watch run index.tsx",
    "start": "bun run index.tsx",
    "build": "bun build ./index.tsx --outdir ./dist --target node",
    "compile": "bun build ./index.tsx --compile --outfile spiffo-up",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@types/ssh2-sftp-client": "^9.0.6",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@byteland/ink-scroll-bar": "^1.0.0",
    "@inkjs/ui": "^2.0.0",
    "@mishieck/ink-titled-box": "^0.4.2",
    "@pppp606/ink-chart": "^0.2.5",
    "@pulumi/gcp": "^9.21.0",
    "@pulumi/pulumi": "^3.232.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "i18next": "^26.0.7",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-confirm-input": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-quicksearch-input": "^1.0.0",
    "ink-scroll-list": "^0.4.1",
    "ink-scroll-view": "^0.3.6",
    "ink-spawn": "^0.1.4",
    "ink-spinner": "^5.0.0",
    "ink-stepper": "^0.2.1",
    "ink-syntax-highlight": "^2.0.2",
    "ink-table": "^3.1.0",
    "ink-task-list": "^2.0.0",
    "ink-text-input": "^6.0.0",
    "rcon-client": "^4.2.5",
    "react": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router": "^7.14.2",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
